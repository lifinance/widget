{
  "name": "nft-checkout",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "analyze": "source-map-explorer 'dist/assets/*.js' --no-border-checks",
    "dev": "vite",
    "build": "tsc && vite build",
    "check:types": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "preview": "vite preview",
    "pre-push:validate": "pnpm check:types"
  },
  "author": "Eugene Chybisov <eugene@li.finance>",
  "dependencies": {
    "@lifi/sdk": "^4.0.0",
    "@lifi/wallet-management": "workspace:*",
    "@lifi/widget": "workspace:*",
    "@lifi/widget-provider-bitcoin": "workspace:*",
    "@lifi/widget-provider-ethereum": "workspace:*",
    "@lifi/widget-provider-solana": "workspace:*",
    "@lifi/widget-provider-sui": "workspace:*",
    "@mui/icons-material": "^9.1.1",
    "@mui/material": "^9.1.1",
    "@mui/system": "^9.1.1",
    "@opensea/seaport-js": "4.1.3",
    "@tanstack/react-query": "^5.101.0",
    "bignumber.js": "^11.1.4",
    "ethers": "^6.17.0",
    "events": "^3.3.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "viem": "^2.52.2",
    "wagmi": "^3.6.17"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "source-map-explorer": "^2.5.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-node-polyfills": "0.26.0",
    "web-vitals": "^5.3.0"
  },
  "browserslist": {
    "production": [
      "> 1%",
      "last 2 versions",
      "not dead",
      "not IE > 0",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "private": true
}
