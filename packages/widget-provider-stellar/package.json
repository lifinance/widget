{
  "name": "@lifi/widget-provider-stellar",
  "version": "4.1.0",
  "description": "LI.FI Widget Provider for Stellar blockchain integration.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.d.ts",
  "sideEffects": false,
  "scripts": {
    "watch": "tsdown --watch",
    "build": "pnpm clean && tsdown",
    "build:prerelease": "node ../../scripts/prerelease.js && cpy '../../README.md' .",
    "build:postrelease": "node ../../scripts/postrelease.js && rm -rf README.md",
    "clean": "rm -rf dist",
    "check:types": "tsc --noEmit",
    "check:circular-deps": "madge --circular $(find ./src -name '*.ts' -o -name '*.tsx')",
    "check:circular-deps-graph": "madge --circular $(find ./src -name '*.ts' -o -name '*.tsx') --image graph.svg"
  },
  "author": "Eugene Chybisov <eugene@li.finance>",
  "homepage": "https://github.com/lifinance/widget",
  "repository": {
    "type": "git",
    "url": "https://github.com/lifinance/widget.git",
    "directory": "packages/widget-provider-stellar"
  },
  "bugs": {
    "url": "https://github.com/lifinance/widget/issues"
  },
  "license": "Apache-2.0",
  "keywords": [
    "widget",
    "lifi-widget",
    "stellar",
    "xlm",
    "wallet",
    "web3",
    "lifi"
  ],
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^2.5.0",
    "@lifi/sdk": "0.0.0-preview-5e098f3",
    "@lifi/sdk-provider-stellar": "0.0.0-preview-5e098f3",
    "@lifi/widget-provider": "workspace:*",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "react": ">=19"
  },
  "devDependencies": {
    "cpy-cli": "^7.0.0",
    "madge": "^8.0.0",
    "react": "^19.2.7",
    "typescript": "^6.0.3"
  }
}
