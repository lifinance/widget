TRANSAK_API_KEY=
TRANSAK_API_SECRET=
TRANSAK_PARTNER_API_BASE=https://api-stg.transak.com
TRANSAK_API_GATEWAY_BASE=https://api-gateway-stg.transak.com
REFERRER_DOMAIN=
PORT=8080

# Switch to real Core endpoint (set to 'true' to proxy requests to Core API)
USE_REAL_CORE=false
CORE_API_URL=

# Error simulation mode (for testing error handling in the widget)
# Options: timeout, auth_error, config_error (leave empty for normal operation)
SIMULATE_ERROR=
# Timeout delay in milliseconds (only used when SIMULATE_ERROR=timeout)
SIMULATE_TIMEOUT_MS=30000
