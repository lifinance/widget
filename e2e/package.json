{
  "name": "@lifi/widget-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright E2E smoke tests for the LI.FI Widget playground",
  "scripts": {
    "test": "playwright test",
    "test:dev": "playwright test --config playwright.dev.config.ts",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report",
    "e2e:examples": "playwright test --config playwright.examples.config.ts",
    "e2e:example": "playwright test --config playwright.examples.config.ts --project"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0"
  }
}
